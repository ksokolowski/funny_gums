#!/usr/bin/env bash
# Pre-commit hook: runs project verifications (mirrors CI)
# This relies on 'make check' to ensure consistency between
# local hooks and CI pipelines.
set -uo pipefail

echo "⚡ Running pre-commit checks..."

# Simple delegation to Make
if ! make check >/dev/null; then
    echo "❌ Checks failed!"
    echo "   Run 'make check' to see the errors."
    echo ""
    exit 1
fi

echo "✅ All checks passed!"
